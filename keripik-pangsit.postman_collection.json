{
  "info": {
    "_postman_id": "keripik-pangsit-api",
    "name": "Keripik Pangsit API",
    "description": "API untuk sistem penjualan Keripik Pangsit - Owner Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "product_id", "value": "p1000000-0000-0000-0000-000000000001", "type": "string" },
    { "key": "product_id_medium", "value": "p1000000-0000-0000-0000-000000000002", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      }
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_produk\": \"Keripik Pangsit\",\n  \"tipe_produk\": \"Keripik Pangsit\",\n  \"rasa\": \"Pedas\",\n  \"ukuran\": \"Medium\",\n  \"harga\": 25000,\n  \"stok\": 50,\n  \"tanggal_buat\": \"2025-10-01\"\n}"
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "Get Products by Date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?tanggal=2025-10-01",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [{ "key": "tanggal", "value": "2025-10-01" }]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction (Customer Baru - Fery)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_customer\": \"Fery\",\n  \"product_id\": \"{{product_id}}\",\n  \"quantity\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/transactions", "host": ["{{base_url}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Create Transaction (Customer Lama - Fenty)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_customer\": \"Fenty\",\n  \"product_id\": \"{{product_id_medium}}\",\n  \"quantity\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/transactions", "host": ["{{base_url}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Get Transactions by Date Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?start_date=2025-10-01&end_date=2025-12-31",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "start_date", "value": "2025-10-01" },
                { "key": "end_date", "value": "2025-12-31" }
              ]
            }
          }
        },
        {
          "name": "Get Transaction Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions/summary?start_date=2025-10-01&end_date=2025-12-31",
              "host": ["{{base_url}}"],
              "path": ["transactions", "summary"],
              "query": [
                { "key": "start_date", "value": "2025-10-01" },
                { "key": "end_date", "value": "2025-12-31" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Redeem Poin",
      "item": [
        {
          "name": "Redeem Poin Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_customer\": \"Fery\",\n  \"ukuran\": \"Small\",\n  \"product_id\": \"{{product_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/redeem", "host": ["{{base_url}}"], "path": ["redeem"] }
          }
        },
        {
          "name": "Get Redeem Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/redeem", "host": ["{{base_url}}"], "path": ["redeem"] }
          }
        }
      ]
    }
  ]
}
